# Service listen port on host
XHS_PORT=18060

# Dockerfile selection
# On Apple Silicon / ARM64 hosts, install/update scripts will append
# XHS_DOCKERFILE=Dockerfile.arm64 automatically when this key is absent.
# You can override it manually if needed.

# Concurrency controls
XHS_MAX_CONCURRENCY=12
XHS_ACCOUNT_MAX_CONCURRENCY=3
XHS_ACQUIRE_TIMEOUT=180s

# Optional proxy. Keep empty if not needed.
# Examples:
# XHS_PROXY=http://user:pass@proxy:port
# XHS_PROXY=socks5://user:pass@proxy:port
XHS_PROXY=
